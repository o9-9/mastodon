- content_for :page_title do
  = t('unsubscriptions.title')

.simple_form
  %h1.title= t('unsubscriptions.complete')
  %p.lead
    = t('unsubscriptions.success_html', domain: content_tag(:strong, site_hostname), type: content_tag(:strong, I18n.t(@type, scope: 'unsubscriptions.emails')), email: content_tag(:strong, @recipient.email))
  %p.lead
    = t('unsubscriptions.resubscribe_html', settings_path: settings_preferences_notifications_path)
