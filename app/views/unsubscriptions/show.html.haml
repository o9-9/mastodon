- content_for :page_title do
  = t('unsubscriptions.title')

.simple_form
  %h1.title= t('unsubscriptions.title')
  %p.lead
    - if @recipient.is_a?(User)
      = t 'unsubscriptions.confirmation_html',
          domain: content_tag(:strong, site_hostname),
          type: content_tag(:strong, I18n.t(@type, scope: 'unsubscriptions.emails')),
          email: content_tag(:strong, @recipient.email),
          settings_path: settings_preferences_notifications_path
    - elsif @recipient.is_a?(EmailSubscription)
      = t 'unsubscriptions.confirmation_for_subscription_html',
          name: content_tag(:strong, "@#{@recipient.account.username}@#{site_hostname}"),
          email: content_tag(:strong, @recipient.email)
  = form_with url: unsubscribe_path do |form|
    = form.hidden_field :token,
                        value: params[:token]
    = form.hidden_field :type,
                        value: params[:type]
    = form.button t('unsubscriptions.action'),
                  type: :submit,
                  class: 'btn'
